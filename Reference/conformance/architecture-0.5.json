    {
      "requirementId": "BR-05-GENESIS-001",
      "architectureRevision": "0.5",
      "component": "Brontide.Reference.Core/GenesisContext",
      "positiveEvidence": [{ "path": "Reference/src/Brontide.Reference.Core/AuthorityDomain.cs", "anchor": "public IReadOnlyList<GenesisRecord> GenesisOccurrences" }],
      "negativeEvidence": [
        { "path": "Reference/tests/Brontide.Reference.Core.Tests/KernelTests.cs", "anchor": "Failed_genesis_occurrence_rolls_back_unrecorded_authority" },
        { "path": "Reference/tests/Brontide.Reference.Core.Tests/KernelTests.cs", "anchor": "Failed_genesis_occurrence_rolls_back_renewal_of_an_existing_lease" },
        { "path": "Reference/tests/Brontide.Reference.Core.Tests/KernelTests.cs", "anchor": "Concurrent_genesis_context_issuance_cannot_resume_after_rollback" }
      ],
      "status": "tested",
      "rationale": "Genesis is callback-scoped and recorded; context validation and mutation share the domain transaction gate, so concurrent issuance cannot resume after deactivation. A failed occurrence atomically restores actors, capabilities, newly issued and pre-existing mutable liveness-lease state, declarations, and Shape registrations. Lease mutation is coordinated with the same gate; rolled-back leases are actively invalidated and registry membership rejects other escaped references, while runtime effects and nested Genesis are blocked during the transaction."
    },
